{
  "description": "Branch-scoped MEMORY.md generator",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh\"",
            "statusMessage": "Loading branch memory",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
